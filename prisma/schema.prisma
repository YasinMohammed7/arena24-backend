// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  name            String
  phone           String           @unique
  ownerId         String? // for sub-users
  isActive        Boolean          @default(true) // for activation/deactivation
  deletedAt       DateTime? // for soft delete
  imageUrl        String?
  userRoles       UserRole[]
  userPermissions UserPermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  RefreshToken  RefreshToken[]
  businesses    Business[]         @relation("OwnedBusinesses")
  locations     Location[]         @relation("LocationOwner")
  manages       LocationManager[]
  businessRoles UserBusinessRole[]

  passwordResetToken PasswordResetToken?

  Reservation Reservation[]

  Review Review[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique // e.g., 'create:location', 'delete:user'
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model Role {
  id              String             @id @default(uuid())
  name            String             @unique // 'PLATFORM_ADMIN', 'EXTERNAL_OWNER', etc.
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  businessRoles   UserBusinessRole[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId]) // composite PK
  @@map("user_roles")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model VerificationCode {
  id        String   @id @default(cuid())
  contact   String   @unique
  code      String // 4-digit code
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("verification_codes")
}

model UserPermission {
  userId       String
  permissionId String
  assignedAt   DateTime  @default(now())
  assignedBy   String? // Optional: track who assigned this permission
  expiresAt    DateTime? // Optional: for temporary permissions

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model Business {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  ownerId     String // Foreign key to User
  owner       User               @relation("OwnedBusinesses", fields: [ownerId], references: [id])
  locations   Location[]
  userRoles   UserBusinessRole[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([name, ownerId]) // Ensure unique business names per owner
  @@index([ownerId]) // Index for faster lookups by owner
  @@index([name]) // Index for faster lookups by business name
  @@map("businesses")
}

model Location {
  id               Int                @id @default(autoincrement())
  type             String // e.g., 'restaurant', 'hotel', 'event venue'
  name             String
  address          String
  contact          String?
  capacity         Int? // Maximum capacity of the location
  latitude         Float?
  longitude        Float?
  experience       String? // Description of the experience offered at the location
  amenities        String? // JSON or string representation of amenities available
  schedule         Schedules[]
  LocationFacility LocationFacility[] // Many-to-many relationship with Facility
  LocationAmenity  LocationAmenity[] // Many-to-many relationship with Amenity
  imageUrl         String? // URL to an image representing the location
  meniuUrl         String? // URL to the public menu for the location
  description      String?            @db.Text
  isActive         Boolean            @default(true) // for activation/deactivation
  deletedAt        DateTime? // for soft delete
  // Optional fields for more detailed location management
  // e.g., opening hours, capacity, etc.
  openingHours     String? // JSON or string representation of opening hours

  // Foreign keys
  // to Business and User (owner)
  businessId   Int // Foreign key to Business
  business     Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  ownerId      String // Foreign key to User
  owner        User               @relation("LocationOwner", fields: [ownerId], references: [id])
  managers     LocationManager[]
  userRoles    UserBusinessRole[]
  events       Event[]
  reservations Reservation[] // reservations for this location
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([name, businessId]) // Ensure unique location names per business
  @@index([businessId]) // Index for faster lookups by business
  @@index([ownerId]) // Index for faster lookups by owner
  @@map("locations")
  Review Review[]
  Offer Offer[]
}

model Schedules {
  id         Int      @id @default(autoincrement())
  locationId Int
  dayOfWeek  String // Sunday, Monday, ...,
  startTime  String // e.g., '09:00'
  endTime    String // e.g., '17:00'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId]) // Index for faster lookups by location
  @@map("schedules")
}

model LocationManager {
  id         Int      @id @default(autoincrement())
  userId     String // Manager user
  locationId Int // Location being managed
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, locationId])
  @@index([locationId]) // Index for faster lookups by location
  @@index([userId]) // Index for faster lookups by user
  @@map("location_managers")
}

model UserBusinessRole {
  id         Int       @id @default(autoincrement())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  businessId Int?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  roleId     String // Changed from 'role String' to reference Role model
  role       Role      @relation(fields: [roleId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, businessId, locationId])
  @@index([userId])
  @@index([businessId])
  @@index([locationId])
  @@index([roleId])
  @@map("user_business_roles")
}

model Facility {
  id        Int      @id @default(autoincrement())
  name      String // e.g., 'WiFi', 'Parking', 'Pool', 'Terasa'
  isActive  Boolean  @default(true) // for activation/deactivation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations LocationFacility[]
  events    EventFacility[]

  @@unique([name]) // Ensure unique facility names
  @@index([name]) // Index for faster lookups by name
  @@map("facilities")
}

model LocationFacility {
  id         Int      @id @default(autoincrement())
  facilityId Int
  locationId Int
  isActive    Boolean  @default(true) // for activation/deactivation
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([facilityId, locationId])
  @@index([facilityId])
  @@index([locationId])
  @@map("location_facilities")
}

model Amenity {
  id          Int      @id @default(autoincrement())
  name        String // e.g., 'WiFi', 'External Battery', 'Blankets', 'Gifts'
  description String? // Optional description of the amenity
  iconUrl     String? // Optional URL to an icon representing the amenity
  isActive    Boolean  @default(true) // for activation/deactivation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  locations LocationAmenity[]

  @@unique([name]) // Ensure unique amenity names
  @@index([name]) // Index for faster lookups by name
  @@map("amenities")
}

model LocationAmenity {
  id         Int      @id @default(autoincrement())
  amenityId  Int
  locationId Int
  isActive    Boolean  @default(true) // for activation/deactivation
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, amenityId])
  @@index([amenityId])
  @@index([locationId])
  @@map("location_amenities")
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  date        DateTime // event day (can also split date & time if you prefer)
  startHour   DateTime
  endHour     DateTime
  address     String
  price       Decimal? @db.Decimal(10, 2)
  maxPeople   Int? // max capacity of the event
  imageUrl         String?
  // Relations
  locationId Int
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  facilities      EventFacility[]
  includedOptions EventIncludedOption[]
  requirements    EventRequirement[]
  reservations    Reservation[] // reservations for this event

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("event")
}

/// Pivot table Event ↔ Facility (many-to-many)
model EventFacility {
  eventId    Int
  facilityId Int
  isActive    Boolean  @default(true) // for activation/deactivation
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([eventId, facilityId])
  @@map("event_facilities")
}

/// Example: welcome drink, live music, dishes, etc
model EventIncludedOption {
  id      Int    @id @default(autoincrement())
  name    String
  eventId Int
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_included_options")
}

/// Example: min age, reservation, dress code, etc
model EventRequirement {
  id      Int    @id @default(autoincrement())
  name    String // could also be enum: AGE, RESERVATION, DRESS_CODE
  eventId Int
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_requirements")
}

model Reservation {
  id     Int     @id @default(autoincrement())
  userId String? // if registered user makes the reservation
  user   User?   @relation(fields: [userId], references: [id])

  name        String // name of person booking
  email       String?
  phone       String?
  peopleCount Int
  status      ReservationStatus @default(PENDING)
  details     String? // any special requests or details

  // Polymorphic relation (reservation for either event OR location)
  eventId Int?
  event   Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([eventId])
  @@index([locationId])
  @@map("reservations")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Media {
  id        String   @id @default(cuid())
  modelType String // e.g. 'Restaurant', 'Event', 'Facility'
  modelId   String // the entity's ID
  type      String // 'cover', 'gallery', 'icon'
  fileName  String
  mimeType  String
  size      Int
  path      String // local file path
  url       String // public URL
  altText   String?
  sortOrder Int?
  createdAt DateTime @default(now())

  @@index([modelType, modelId])
  @@map("media")
}

model Review {
  id         Int       @id @default(autoincrement())
  comment    String?   @db.Text
  stars      Int       // 1–5 stars rating

  // Relations
  userId     String
  user       User      @relation(fields: [userId], references: [id])

  locationId Int
  location   Location  @relation(fields: [locationId], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  @@unique([userId, locationId]) // one review per user per location
  @@index([userId])
  @@index([locationId])
  @@map("reviews")
}

model Offer {
  id           Int        @id @default(autoincrement())
  name         String
  description  String?    @db.Text
  image        String?
  startDate    DateTime
  endDate      DateTime
  discount     Int?       // percentage discount (0-100)

  // Optional location (null = global offer)
  locationId   Int?
  location     Location?   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Category for filtering
  categoryId   Int
  category     OfferCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@index([locationId])
  @@index([categoryId])
  @@map("offers")
}

model OfferCategory {
  id       Int      @id @default(autoincrement())
  name     String   // Breakfast, Burgers, Pizza, Cocktails, etc
  offers   Offer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([name])
  @@index([name])
  @@map("offer_categories")
}